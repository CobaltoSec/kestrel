# Kestrel — configuration
# Copy to .env and fill in your values
# Never commit .env to git

# ─── HTB API ───────────────────────────────────────────────────────────────────
# Get from: hackthebox.com → Settings → API Key
HTB_API_TOKEN=your_htb_api_token_here
HTB_USER_ID=your_htb_user_id_here

# ─── Kali VM (execution platform) ─────────────────────────────────────────────
KALI_HOST=192.168.x.x
KALI_USER=kali
KALI_SSH_KEY=~/.ssh/kali-pentest

# ─── Session storage ──────────────────────────────────────────────────────────
# Where engagement files are saved (intel.md, estado.md, loot/, etc.)
KESTREL_SESSIONS_DIR=~/htb-sessions

# State directory (last-cycle.json, profile.json)
KESTREL_STATE_DIR=~/.kestrel/state

# ─── Optional: pgvector KB (blind mode technique context) ─────────────────────
# Set KESTREL_KB_PATH to the directory containing kb/query/smart.py
# Leave empty to skip KB queries (blind_fingerprint.py works without it)
KESTREL_KB_PATH=
KB_PGVECTOR_HOST=localhost
KB_PGVECTOR_PORT=5433
KB_PGVECTOR_DB=vectors
